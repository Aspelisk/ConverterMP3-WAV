<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10" style="-fx-padding: 15;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.ControllerApp">

    <!-- Заголовок -->
    <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="🎵 MP3 -&gt; WAV Converter">
        <padding>
            <Insets bottom="10" />
        </padding>
    </Label>

    <!-- Поле ввода -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label prefWidth="120" text="📥 Входной файл:" />
        <TextField fx:id="inputPathField" promptText="Путь к .mp3 файлу" HBox.hgrow="ALWAYS" />
        <Button fx:id="browseInputBtn" text="Обзор..." />
    </HBox>

    <!-- Поле вывода -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label prefWidth="120" text="📤 Выходной файл:" />
        <TextField fx:id="outputPathField" prefHeight="26.0" prefWidth="202.0" promptText="Путь для сохранения .wav" HBox.hgrow="ALWAYS" />
        <Button fx:id="browseOutputBtn" text="Обзор..." />
    </HBox>

    <!-- Кнопка конвертации -->
    <Button fx:id="convertBtn" alignment="CENTER" prefWidth="200" style="-fx-base: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold;" text="▶ Начать конвертацию">
        <padding>
            <Insets top="5" />
        </padding>
    </Button>

    <!-- Статус и прогресс -->
    <VBox spacing="5">
        <Label fx:id="statusLabel" style="-fx-font-style: italic;" text="Ожидание..." />
        <HBox fx:id="progressBox" alignment="CENTER_LEFT" spacing="10">
            <ProgressBar fx:id="progressBar" prefWidth="300" progress="0" />
        </HBox>
    </VBox>

    <!-- Лог -->
    <Label style="-fx-font-weight: bold;" text="📋 Лог операций:" />
    <TextArea fx:id="logArea" editable="false" prefHeight="120" style="-fx-control-inner-background: #f9f9f9;" />

    <padding>
        <Insets bottom="10" left="10" right="10" top="10" />
    </padding>

</VBox>
